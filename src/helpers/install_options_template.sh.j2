################################################################################
# IBM Software Hub install-options.yml
# Generated based on selected components
################################################################################
{% if "analyticsengine" in components_to_install %}
---
# ............................................................................
# Analytics Engine powered by Apache Spark parameters
# ............................................................................
non_olm:
  analyticsengine:

# ------------------------------------------------------------------------------
# Analytics Engine powered by Apache Spark service configuration parameters
# ------------------------------------------------------------------------------
# This preset is meant to not over-commit nodes on the cluster which is very easy with larger configs of analyticsengine.
    serviceConfig:
      sparkAdvEnabled: true
      jobAutoDeleteEnabled: true
      kernelCullTime: 30
      imagePullParallelism: "10"
      imagePullCompletions: "6"
      kernelCleanupSchedule: "*/30 * * * *"
      jobCleanupSchedule: "*/30 * * * *"
      skipSelinuxRelabeling: false
      mountCustomizationsFromCchome: false

# ------------------------------------------------------------------------------
# Spark runtime configuration parameters
# ------------------------------------------------------------------------------
    sparkRuntimeConfig:
      maxDriverCpuCores: 2
      maxExecutorCpuCores: 3
      maxDriveMemory: "2g"
      maxExecutorMemory: "4g"
      maxNumWorkers: 6
      localDirScaleFactor: 5
{% endif %}{% if "replication" in components_to_install %}
---
# ............................................................................
# Data Replication parameters 
# Valid licenseType values:
#   IDRC - Specify this option if you purchased the IBM Data Replication Cartridge for IBM Software Hub.
#   IIDRC - Specify this option if you purchased the IBM InfoSphere® Data Replication Cartridge for IBM Software Hub.
#   IDRM - Specify this option if you purchased IBM Data Replication Modernization.
#   IIDRM - Specify this option if you purchased IBM InfoSphere Data Replication Modernization.
#   IDRZOS - Specify this option if you purchased IBM Data Replication for Db2® z/OS® Cartridge.
#   IIDRWXTO - Specify this option if you purchased IBM InfoSphere Data Replication for watsonx.data Cartridge.
# ............................................................................
non_olm:
  replication:
    licenseType: IDRC
{% endif %}{% if "wkc" in components_to_install %}
---
# ............................................................................
# IBM Knowledge Catalog parameters
# ............................................................................
non_olm:
  wkc:
    enableDataQuality: False
    enableKnowledgeGraph: True
    useFDB: False
{% endif %}{% if "ikc_premium" in components_to_install %}
---
# ............................................................................
# IBM Knowledge Catalog Premium parameters
# enableModelsOn - valid options: 'cpu','gpu','remote' (remote = watsonx.ai)
# ............................................................................
non_olm:
  ikcPremium:
    enableDataQuality: False
    enableKnowledgeGraph: True
    useFDB: False
    enableAISearch: False
    enableSemanticAutomation: False
    enableSemanticEnrichment: True
    enableSemanticEmbedding: False
    enableTextToSql: False
    enableModelsOn: 'remote'
#    customModelTextToSQL: granite-3-8b-instruct # leave commented out if enableModelsOn is set to 'remote'.
{% endif %}{% if "ikc_standard" in components_to_install %}
---
# ............................................................................
# IBM Knowledge Catalog Standard parameters
# ............................................................................
non_olm:
  ikcStandard:
    enableKnowledgeGraph: True
    useFDB: False
    enableAISearch: False
    enableSemanticAutomation: False
    enableSemanticEnrichment: True
    enableSemanticEmbedding: False
    enableTextToSql: False
    enableModelsOn: 'remote'
#    customModelTextToSQL: granite-3-8b-instruct
{% endif %}{% if "datalineage" in components_to_install %}
---
# ............................................................................
# IBM Manta Data Lineage parameters 
# Note: requires wkc with enableKnowledgeGraph: True and useFDB: False
# ............................................................................
